{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "lib": [
      "DOM",
      "ES6"
    ],
    "module": "ESNext",
    "moduleResolution": "node",
    "noImplicitAny": true,
    "strictNullChecks": true,
    "target": "ES6",
    "allowJs": false
  },
  "include": [
    "**/*.ts"
  ]
}
